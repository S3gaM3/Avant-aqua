# See https://help.github.com/articles/ignoring-files/

# --- Dependencies ---
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.pnpm-store/
package-lock.json

# --- Build outputs ---
.next/
out/
dist/
build/
*.tsbuildinfo
next-env.d.ts

# --- Environment & secrets (never commit real values) ---
.env
.env.*
!.env.example
!**/.env.example
*.pem
*.key
*.p12
*.pfx
id_rsa
id_rsa.*
id_ed25519
id_ed25519*
*.ppk

deploy/.prod-api.env
deploy/.prod-web.env
deploy/.prod-api-tunnel.env
deploy/.db-pass.txt
deploy/catalog-dump.sql

# --- Deploy artifacts (generated on build machine) ---
deploy/bundle/
deploy/*.tgz
deploy/*.tar.gz
deploy/*.tar
deploy/.web-deploy.tar.gz

# --- User uploads & media (served from disk / CDN) ---
uploads/
apps/api/uploads/
public/uploads/

# --- Import dumps, backups, large binaries ---
import-cache/
data/
backups/
*.wpress
avant-aqua-ru-*/
wordpress-avant/
/*.sql
/*.sqlite
/*.sqlite3
/*.xlsx
/*.zip
/*.tar
/*.tar.gz
/*.7z

# --- Testing ---
coverage/
playwright-report/
test-results/
*.trace
*.har

# --- Logs & debug ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# --- Tooling caches ---
.cache/
tmp/
/tmp/
.turbo/
.vercel

# --- Storybook ---
*storybook.log
storybook-static

# --- OS ---
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# --- IDE / editor ---
.idea/
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
.cursor/
*.swp
*.swo
*~

# --- Local git / merge artifacts ---
.git-rebase-backup/
*.orig
*.rej

# --- Accidental junk ---
n ?*
